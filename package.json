{
  "name": "monorepo-package-boilerplate",
  "version": "0.0.0",
  "private": true,
  "description": "🚀 A modern multi-scenario monorepo boilerplate for building component libraries & npm packages. 一套面向多场景的现代化组件库 monorepo 模板。",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CongYao1993/monorepo-package-boilerplate.git"
  },
  "homepage": "https://github.com/CongYao1993/monorepo-package-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/CongYao1993/monorepo-package-boilerplate/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "init": "tsx scripts/init.ts",
    "create:package": "tsx scripts/create-package.ts",
    "build": "tsx scripts/build.ts",
    "dev": "pnpm --filter playground dev",
    "dev:playground": "pnpm --filter playground dev",
    "docs:api": "pnpm tsx scripts/gen-api-docs.ts",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r --if-present typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "clean": "pnpm -r exec rimraf dist && rimraf docs/.vitepress/dist coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "tinyglobby": "^0.2.16",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.0.0"
}
